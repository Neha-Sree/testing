# Copy to ".env" in this folder (backend/.env) and fill in values.
# backend/.env is gitignored — never commit real keys.

# Google AI (Gemini) — get a key from https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Optional override (default: gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash
